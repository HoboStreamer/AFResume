---
import Base from "../layouts/Base.astro";
import ProjectGrid from "../components/ProjectGrid.astro";
---
<Base title="Portfolio — Alex Frison">
  <section class="container portfolio-head">
    <div class="section-eyebrow">Portfolio</div>
    <h1>Selected work</h1>
    <p class="portfolio-lead">
      Tools, products, agents, and platforms — across Amazon analytics, the
      Hobo Network (HoboStreamer, HoboQuest, HoboMaps, hobo.tools), Python utilities, game dev, and hardware.
    </p>
  </section>
  <ProjectGrid />
</Base>

<style>
  .portfolio-head { padding: 80px 0 0; max-width: 800px; }
  .portfolio-head h1 { font-size: clamp(2.2rem, 5vw, 3.4rem); }
  .portfolio-lead { color: var(--muted); font-size: 1.08rem; }
</style>
